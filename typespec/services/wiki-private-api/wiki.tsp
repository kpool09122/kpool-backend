using TypeSpec.Http;
using KPool.Common;

namespace KPool.WikiPrivateApi;

@doc("Request body for creating a wiki draft.")
model CreateWikiRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
  @doc("Language of the wiki.")
  language: string;
  @doc("Unique slug for the wiki.")
  slug: string;
  @doc("Basic wiki content payload.")
  basic: unknown;
  @doc("Section content payloads.")
  sections?: unknown[];
  @doc("Theme color applied to the wiki.")
  themeColor?: string;
  @doc("Published wiki identifier to branch from.")
  publishedWikiIdentifier?: Uuid;
}

@doc("Request body for automatically creating a wiki draft.")
model AutoCreateWikiRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
  @doc("Language of the wiki.")
  language: string;
  @doc("Display name of the wiki.")
  name: string;
}

@doc("Request body for updating a wiki draft.")
model UpdateWikiDraftRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
  @doc("Basic wiki content payload.")
  basic: unknown;
  @doc("Section content payloads.")
  sections?: unknown[];
  @doc("Theme color applied to the wiki.")
  themeColor?: string;
}

@doc("Request body for wiki workflow actions.")
model WikiWorkflowRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
}

@doc("Request body for publishing a wiki.")
model PublishWikiRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
  @doc("Published wiki identifier to update.")
  publishedWikiIdentifier?: Uuid;
}

@doc("Request body for rolling back a wiki to a previous version.")
model RollbackWikiRequestBody extends WikiAssociationTargets {
  @doc("Resource type that the wiki belongs to.")
  resourceType: string;
  @doc("Version number to roll back to.")
  targetVersion: int32;
}

@doc("Response returned when a wiki draft is created or updated.")
model CreateDraftWikiResponse {
  @statusCode statusCode: 201;
  @body body: DraftWikiSummary;
}

@doc("Response returned when a group draft wiki is fetched.")
model GetGroupDraftWikiResponse {
  @statusCode statusCode: 200;
  @body body: DraftWikiDetail;
}

@doc("Response returned when a talent draft wiki is fetched.")
model GetTalentDraftWikiResponse {
  @statusCode statusCode: 200;
  @body body: TalentDraftWikiDetail;
}

@doc("Response returned when a song draft wiki is fetched.")
model GetSongDraftWikiResponse {
  @statusCode statusCode: 200;
  @body body: SongDraftWikiDetail;
}

@doc("Response returned when an agency draft wiki is fetched.")
model GetAgencyDraftWikiResponse {
  @statusCode statusCode: 200;
  @body body: AgencyDraftWikiDetail;
}

@doc("Response returned when a wiki is published.")
model CreatePublishedWikiResponse {
  @statusCode statusCode: 201;
  @body body: PublishedWikiSummary;
}

@doc("Response body for wiki translation results.")
model TranslateWikiResponseBody {
  @doc("Draft wikis generated by the translation action.")
  draftWikis: DraftWikiSummary[];
}

@doc("Response returned when wiki translation succeeds.")
model TranslateWikiResponse {
  @statusCode statusCode: 201;
  @body body: TranslateWikiResponseBody;
}

@doc("Response body for wiki rollback results.")
model RollbackWikiResponseBody {
  @doc("Published wikis produced by the rollback action.")
  wikis: PublishedWikiSummary[];
}

@doc("Response returned when wiki rollback succeeds.")
model RollbackWikiResponse {
  @statusCode statusCode: 201;
  @body body: RollbackWikiResponseBody;
}

@route("/wiki")
interface WikiOperations {
  @post
  @route("/create")
  @doc("Create a new wiki draft.")
  createWiki(
    @body body: CreateWikiRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/auto-create")
  @doc("Automatically create a wiki draft from the provided metadata.")
  autoCreateWiki(
    @body body: AutoCreateWikiRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/approve")
  @doc("Approve a wiki draft.")
  approveWiki(
    @path wikiId: Uuid,
    @body body: WikiWorkflowRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/edit")
  @doc("Edit an existing wiki draft.")
  editWiki(
    @path wikiId: Uuid,
    @body body: UpdateWikiDraftRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/merge")
  @doc("Merge changes into an existing wiki draft.")
  mergeWiki(
    @path wikiId: Uuid,
    @body body: UpdateWikiDraftRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/publish")
  @doc("Publish a wiki draft.")
  publishWiki(
    @path wikiId: Uuid,
    @body body: PublishWikiRequestBody,
  ): CreatePublishedWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/reject")
  @doc("Reject a wiki draft.")
  rejectWiki(
    @path wikiId: Uuid,
    @body body: WikiWorkflowRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/rollback")
  @doc("Roll back a wiki to a previous published version.")
  rollbackWiki(
    @path wikiId: Uuid,
    @body body: RollbackWikiRequestBody,
  ): RollbackWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/submit")
  @doc("Submit a wiki draft for review.")
  submitWiki(
    @path wikiId: Uuid,
    @body body: WikiWorkflowRequestBody,
  ): CreateDraftWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @post
  @route("/{wikiId}/translate")
  @doc("Translate a wiki draft into additional languages.")
  translateWiki(
    @path wikiId: Uuid,
    @body body: WikiWorkflowRequestBody,
  ): TranslateWikiResponse | KPool.Common.ForbiddenProblemResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.ConflictProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @get
  @route("/{language}/group/{slug}/draft")
  @doc("Fetch the group draft wiki used by the editor.")
  getGroupDraftWiki(
    @path language: string,
    @path slug: string,
  ): GetGroupDraftWikiResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @get
  @route("/{language}/talent/{slug}/draft")
  @doc("Fetch the talent draft wiki used by the editor.")
  getTalentDraftWiki(
    @path language: string,
    @path slug: string,
  ): GetTalentDraftWikiResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @get
  @route("/{language}/song/{slug}/draft")
  @doc("Fetch the song draft wiki used by the editor.")
  getSongDraftWiki(
    @path language: string,
    @path slug: string,
  ): GetSongDraftWikiResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;

  @get
  @route("/{language}/agency/{slug}/draft")
  @doc("Fetch the agency draft wiki used by the editor.")
  getAgencyDraftWiki(
    @path language: string,
    @path slug: string,
  ): GetAgencyDraftWikiResponse | KPool.Common.NotFoundProblemResponse | KPool.Common.UnprocessableEntityProblemResponse | KPool.Common.InternalServerErrorProblemResponse;
}

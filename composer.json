{
    "name": "kpool/backend",
    "description": "PHP Project with PHPUnit",
    "type": "project",
    "require": {
        "php": "^8.5",
        "symfony/uid": "^8.0",
        "laravel/framework": "^13.0",
        "psr/log": "^3.0",
        "ext-mbstring": "*",
        "stripe/stripe-php": "^20.0",
        "ext-gd": "*",
        "google/cloud-translate": "^2.1",
        "sentry/sentry-laravel": "^4.25"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^13.0",
        "friendsofphp/php-cs-fixer": "^3.86",
        "phpstan/phpstan": "^2.1",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "illuminate/console": "*",
        "illuminate/support": "*",
        "illuminate/database": "*",
        "phpunit/php-code-coverage": "^13.0",
        "larastan/larastan": "^3.9",
        "barryvdh/laravel-ide-helper": "^3.6",
        "driftingly/rector-laravel": "^2.3",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "files": [
            "application/helpers.php"
        ],
        "psr-4": {
            "Source\\": "src/",
            "Application\\": "application/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs-fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "phpstan": "./vendor/bin/phpstan analyse --memory-limit=512M",
        "test": "vendor/bin/phpunit --coverage-html coverage-html",
        "test-no-report": "vendor/bin/phpunit"
    }
}
